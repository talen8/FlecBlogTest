/* 登录页面样式 */

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #fff;
  padding: 0 48rpx;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 82, 217, 0.1);
  border-radius: 50%;
  margin-bottom: 32rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  flex: 1;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label text {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #333;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.form-input.error {
  border-color: #e57373;
  background-color: #fff;
}

.form-error {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #e57373;
}

/* 微信登录按钮 */
.wechat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin-top: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid #e5e5e5;
}

.wechat-btn-text {
  margin-left: 12rpx;
  font-size: 30rpx;
  color: #333;
}
