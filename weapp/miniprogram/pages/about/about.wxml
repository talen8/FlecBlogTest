<!-- 关于页面 -->
<view class="about-page">
  <!-- 提醒横幅 -->
  <notice-banner />

  <view class="about-content">
    <view wx:if="{{loading}}" class="loading-wrapper">
      <t-loading size="80rpx" />
    </view>

    <block wx:else>
    <!-- 头部：头像 + 基本信息 -->
    <view class="header">
      <image
        wx:if="{{authorAvatar}}"
        class="avatar"
        src="{{authorAvatar}}"
        mode="aspectFill"
      />
      <view class="header-info">
        <text class="header-name">{{author || '博主'}}</text>
      </view>
    </view>

    <!-- 站点统计 -->
    <view wx:if="{{stats}}" class="block">
      <view class="row stats-row">
        <view class="stat-item">
          <text class="stat-num">{{stats.total_articles}}</text>
          <text class="stat-label">文章</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.total_categories}}</text>
          <text class="stat-label">分类</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.total_tags}}</text>
          <text class="stat-label">标签</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.total_moments}}</text>
          <text class="stat-label">动态</text>
        </view>
      </view>
    </view>

    <!-- 访问统计 -->
    <view wx:if="{{stats}}" class="block">
      <view class="row">
        <text class="row-label">今日</text>
        <text class="row-value">{{stats.today_visitors}} 访客 / {{stats.today_pageviews}} 访问</text>
      </view>
      <view class="row">
        <text class="row-label">昨日</text>
        <text class="row-value">{{stats.yesterday_visitors}} 访客 / {{stats.yesterday_pageviews}} 访问</text>
      </view>
      <view class="row">
        <text class="row-label">本月</text>
        <text class="row-value">{{stats.month_pageviews}} 次访问</text>
      </view>
    </view>
    </block>
  </view>
</view>
