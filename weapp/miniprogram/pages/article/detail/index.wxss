.detail-page {
  min-height: 100vh;
  background-color: #fff;
}

.state-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  gap: 24rpx;
}

.state-text {
  font-size: 28rpx;
  color: #999;
}

.article-wrap {
  padding: 32rpx;
}

.article-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f1f1f;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.meta-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.meta-original {
  margin-left: auto;
  color: var(--theme-color);
  font-weight: 500;
}

.meta-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.tag-category {
  background-color: rgba(0, 82, 217, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: var(--theme-color);
  font-weight: 500;
}

.tag-item {
  background-color: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.content-divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 24rpx 0;
}

.rich-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
}

/* towxml 内容样式增强 */
.rich-content .h1 {
  font-size: 44rpx;
  font-weight: 700;
  margin: 32rpx 0 16rpx;
  line-height: 1.4;
}

.rich-content .h2 {
  font-size: 40rpx;
  font-weight: 600;
  margin: 28rpx 0 14rpx;
  line-height: 1.4;
}

.rich-content .h3 {
  font-size: 36rpx;
  font-weight: 600;
  margin: 24rpx 0 12rpx;
  line-height: 1.4;
}

.rich-content .p {
  margin: 16rpx 0;
  line-height: 1.8;
}

.rich-content .blockquote {
  border-left: 6rpx solid var(--theme-color);
  padding: 16rpx 24rpx;
  margin: 20rpx 0;
  background-color: #f5f7fa;
  border-radius: 0 8rpx 8rpx 0;
}

.rich-content .code {
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  font-family: 'Fira Code', 'Monaco', monospace;
}

.rich-content .pre {
  background-color: #282c34;
  padding: 24rpx;
  border-radius: 12rpx;
  overflow-x: auto;
  margin: 20rpx 0;
}

.rich-content .pre .code {
  background-color: transparent;
  padding: 0;
  color: #abb2bf;
}

.rich-content .table {
  width: 100%;
  border-collapse: collapse;
  margin: 20rpx 0;
}

.rich-content .th,
.rich-content .td {
  border: 1rpx solid #e0e0e0;
  padding: 12rpx 16rpx;
  text-align: left;
}

.rich-content .th {
  background-color: #f5f5f5;
  font-weight: 600;
}

.rich-content .img {
  max-width: 100%;
  height: auto;
  border-radius: 8rpx;
  margin: 20rpx 0;
}

.rich-content .a {
  color: var(--theme-color);
  text-decoration: none;
}

.rich-content .ul,
.rich-content .ol {
  padding-left: 40rpx;
  margin: 16rpx 0;
}

.rich-content .li {
  margin: 8rpx 0;
  line-height: 1.6;
}

.rich-content .hr {
  border: none;
  border-top: 1rpx solid #e0e0e0;
  margin: 32rpx 0;
}

.rich-content .strong {
  font-weight: 600;
}

.rich-content .em {
  font-style: italic;
}

.rich-content .mark {
  background-color: #fff3cd;
  padding: 2rpx 6rpx;
  border-radius: 4rpx;
}

.rich-content .del {
  text-decoration: line-through;
  color: #999;
}

.read-original {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 48rpx 0 24rpx;
  padding: 24rpx;
  border: 2rpx solid var(--theme-color);
  border-radius: 12rpx;
}

.read-original-text {
  font-size: 28rpx;
  color: var(--theme-color);
  font-weight: 500;
}
