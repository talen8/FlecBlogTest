.video-block {
  margin: 24rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #000;
}

.video-player {
  width: 100%;
  height: 420rpx;
}

.video-link {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  background-color: #f5f5f5;
}

.video-link:active {
  background-color: #eee;
}

.video-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--theme-color);
  border-radius: 12rpx;
  margin-right: 20rpx;
  font-size: 40rpx;
}

.video-info {
  flex: 1;
}

.video-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.video-hint {
  font-size: 24rpx;
  color: #999;
}

.video-arrow {
  font-size: 32rpx;
  color: var(--theme-color);
}
