.note {
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: 12rpx;
  border-left: 8rpx solid;
}

.note-info,
.note-tip {
  background-color: #e8f4fd;
  border-left-color: var(--theme-color);
}

.note-warning,
.note-warn {
  background-color: #fff7e6;
  border-left-color: #fa8c16;
}

.note-danger,
.note-error {
  background-color: #fff1f0;
  border-left-color: #ff4d4f;
}

.note-success {
  background-color: #f6ffed;
  border-left-color: #52c41a;
}

.note-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.note-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.note-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.note-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}
