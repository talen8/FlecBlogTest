.link-card {
  margin: 24rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #fff;
  border: 1rpx solid #e0e0e0;
}

.link-type {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  color: #fff;
  background-color: var(--theme-color);
}

.link-card.external .link-type {
  background-color: #ababab;
}

.link-main {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
}

.link-main:active {
  background-color: #f5f5f5;
}

.link-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.icon-text {
  font-size: 32rpx;
}

.link-info {
  flex: 1;
  overflow: hidden;
}

.link-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-text {
  font-size: 28rpx;
  color: var(--theme-color);
}
