.photo-wall {
  margin: 24rpx 0;
}

.photo-row {
  display: grid;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.photo-item {
  position: relative;
  overflow: hidden;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.photo-img {
  width: 100%;
  height: 200rpx;
  display: block;
}

.photo-item:active {
  opacity: 0.9;
}
