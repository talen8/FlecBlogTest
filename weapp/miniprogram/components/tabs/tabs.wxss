.tabs {
  margin: 24rpx 0;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #fff;
}

.tabs-header {
  display: flex;
  background-color: #f5f5f5;
  border-bottom: 1rpx solid #e0e0e0;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-btn {
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  cursor: pointer;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.tab-btn:active {
  background-color: #eee;
}

.tab-btn.active {
  color: var(--theme-color);
  font-weight: 500;
  border-bottom-color: var(--theme-color);
  background-color: #fff;
}

.tabs-content {
  padding: 24rpx;
}

.tab-panel {
  display: none;
}

.tab-panel.active {
  display: block;
}
