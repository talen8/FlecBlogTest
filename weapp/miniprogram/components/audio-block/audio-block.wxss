.audio-block {
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.audio-main {
  display: flex;
  align-items: center;
}

.audio-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--theme-color);
  border-radius: 50%;
  margin-right: 20rpx;
}

.audio-icon:active {
  opacity: 0.8;
}

.icon-text {
  font-size: 32rpx;
  color: #fff;
}

.audio-info {
  flex: 1;
  overflow: hidden;
}

.audio-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.audio-progress {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background-color: #ddd;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background-color: var(--theme-color);
  border-radius: 4rpx;
  transition: width 0.1s linear;
}

.progress-time {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
}
